{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DS-Monitor",
  "version": "0.1.0",
  "identifier": "com.dsmonitor.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DS-Monitor",
        "width": 360,
        "height": 360,
        "minWidth": 340,
        "minHeight": 260,
        "maxHeight": 720,
        "decorations": false,
        "resizable": false,
        "maximizable": false,
        "center": true,
        "visible": false,
        "focus": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "DS-Monitor"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
