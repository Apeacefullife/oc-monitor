{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OC-Monitor",
  "version": "0.1.0",
  "identifier": "com.ocmonitor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OC-Monitor",
        "width": 360,
        "height": 360,
        "minWidth": 340,
        "minHeight": 260,
        "maxHeight": 720,
        "decorations": false,
        "resizable": false,
        "maximizable": false,
        "center": true,
        "visible": false,
        "focus": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
